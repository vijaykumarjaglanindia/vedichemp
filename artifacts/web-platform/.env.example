# VEDIC HEMP — environment
# Copy to .env and fill in. The app connects as vedichemp_app (no UPDATE/DELETE
# on the WORM tables); migrations run as vedichemp_migrator. See prisma/roles.sql.

# Application role — used at runtime by the app (least privilege).
DATABASE_URL="postgresql://vedichemp_app:CHANGEME@localhost:5432/vedichemp?schema=public"

# Migrator role — used ONLY by `prisma migrate` and the raw SQL migrations.
MIGRATE_DATABASE_URL="postgresql://vedichemp_migrator:CHANGEME@localhost:5432/vedichemp?schema=public"

# Auth.js — passkeys for admin (SMS OTP is NOT accepted for admin auth),
# email+OTP for buyers.
AUTH_SECRET="CHANGEME-generate-a-long-random-string"
AUTH_URL="http://localhost:3000"

# Sensitive object storage (prescriptions, medical notes) — a SEPARATE bucket
# with object lock and a SEPARATE KMS CMK from the CoA/audit mirror bucket.
SENSITIVE_BUCKET="vedichemp-sensitive-ap-south-1"
SENSITIVE_KMS_KEY_ID="arn:aws:kms:ap-south-1:000000000000:key/CHANGEME"
COA_BUCKET="vedichemp-coa-ap-south-1"

# Data residency: all PII/payment data in Indian regions.
AWS_REGION="ap-south-1"

NODE_ENV="development"
