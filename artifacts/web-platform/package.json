{
  "name": "vedichemp",
  "version": "0.1.0",
  "private": true,
  "description": "Regulated multi-vendor marketplace for hemp, CBD wellness, Ayurveda and medical cannabis in India.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "db:roles": "psql \"$MIGRATE_DATABASE_URL\" -f prisma/roles.sql",
    "db:migrate": "prisma migrate dev",
    "db:prohibitions": "psql \"$MIGRATE_DATABASE_URL\" -f prisma/migrations/0001_prohibitions/migration.sql && psql \"$MIGRATE_DATABASE_URL\" -f prisma/migrations/0002_recall_delete_immutable/migration.sql && psql \"$MIGRATE_DATABASE_URL\" -f prisma/migrations/0003_idempotency_keys/migration.sql",
    "db:verify": "psql \"$DATABASE_URL\" -c 'SELECT * FROM prohibition_status'",
    "db:fixture": "tsx scripts/fixture.ts",
    "test": "vitest run",
    "test:prohibitions": "vitest run tests/prohibitions.test.ts",
    "predeploy": "pnpm test:prohibitions && pnpm typecheck"
  },
  "dependencies": {
    "@prisma/client": "^6.2.1",
    "lucide-react": "^1.24.0",
    "next": "^15.1.6",
    "next-auth": "^5.0.0-beta.25",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "axe-core": "^4.12.1",
    "prisma": "^6.2.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^4.1.10"
  }
}
