// VEDIC HEMP — Prisma schema
// Money is ALWAYS integer paise. Never Float. Never client-supplied.
// Constraints that enforce prohibitions A1–A6 live in prisma/migrations/0001_prohibitions.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── ENUMS ───────────────────────────

enum ComplianceClass {
  HEMP_FOOD
  AYURVEDA
  CBD_WELLNESS
  MED_CANNABIS
}

enum UserRole {
  BUYER
  BUYER_VERIFIED
  BUYER_RX
  CAREGIVER
}

enum SellerRole {
  SELLER_OWNER
  SELLER_ADMIN
  SELLER_CATALOGUE
  SELLER_PRICING
  SELLER_INVENTORY
  SELLER_ORDERS
  SELLER_FINANCE
  SELLER_ADS
  SELLER_SUPPORT
  SELLER_PHARMACIST
  SELLER_READONLY
}

enum AdminRole {
  ADMIN_OWNER
  ADMIN_SECURITY
  ADMIN_COMPLIANCE
  ADMIN_PHARMACIST
  ADMIN_SELLER_OPS
  ADMIN_CATALOGUE
  ADMIN_ORDER_OPS
  ADMIN_DISPUTE
  ADMIN_GRIEVANCE
  ADMIN_FINANCE
  ADMIN_FINANCE_APPROVER
  ADMIN_ADS
  ADMIN_CMS
  ADMIN_MARKETING
  ADMIN_SUPPORT
  ADMIN_ANALYST
  ADMIN_AUDITOR
}

enum SellerState {
  REGISTERED
  KYC_PENDING
  KYC_APPROVED
  KYC_REJECTED
  ACTIVE
  AT_RISK
  SUSPENDED
  DEACTIVATED
  CLOSED
}

enum ListingState {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  LIVE
  PAUSED
}

enum LabReportStatus {
  PENDING
  APPROVED
  REJECTED
}

enum PrescriptionStatus {
  PENDING
  VERIFIED
  REJECTED
  EXPIRED
}

enum OrderStatus {
  PLACED
  ACCEPTED
  PACKED
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURNED
}

enum SettlementStatus {
  DRAFT
  AWAITING_CHECKER
  POSTED
  PAID
}

enum AuditOutcome {
  SUCCESS
  DENIED
  ERROR
}

// ─────────────────────────── IDENTITY ───────────────────────────

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  mobile        String?    @unique
  firstName     String
  lastName      String?
  dob           DateTime? // write-once; changes need support + ID proof
  dobVerifiedAt DateTime?
  roles         UserRole[] @default([BUYER])
  createdAt     DateTime   @default(now())
  deletedAt     DateTime? // soft delete; purged at 30 days

  addresses     Address[]
  orders        Order[]
  prescriptions Prescription[]
  wallet        Wallet?
  consents      Consent[]

  @@index([email])
}

model AdminUser {
  id        String      @id @default(uuid())
  email     String      @unique
  name      String
  roles     AdminRole[]
  // Separation of duties is enforced at grant time — see src/server/rbac.ts.
  // FINANCE ⊕ FINANCE_APPROVER, DISPUTE ⊕ GRIEVANCE, ANALYST ⊕ SUPPORT.
  createdAt DateTime    @default(now())
  disabledAt DateTime?
}

model Consent {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  purpose   String // analytics | marketing | personalisation
  granted   Boolean
  at        DateTime @default(now())

  // Append-only: withdrawal is a new row, never an update.
  @@index([userId, purpose])
}

model Address {
  id         String  @id @default(uuid())
  userId     String
  user       User    @relation(fields: [userId], references: [id])
  label      String
  line       String
  city       String
  state      String
  pincode    String
  phone      String
  isDefault  Boolean @default(false)

  @@index([userId])
}

// ─────────────────────────── SELLER ───────────────────────────

model Seller {
  id        String      @id @default(uuid())
  legalName String
  gstin     String      @unique
  pan       String
  state     SellerState @default(REGISTERED)
  healthScore Int       @default(0)
  createdAt DateTime    @default(now())

  licences  Licence[]
  products  Product[]
  campaigns AdCampaign[]
  settlements Settlement[]
}

model Licence {
  id              String          @id @default(uuid())
  sellerId        String
  seller          Seller          @relation(fields: [sellerId], references: [id])
  type            String // FSSAI | AYUSH | STATE_DRUG | LEGAL_METROLOGY
  number          String
  authority       String
  validTill       DateTime
  verified        Boolean         @default(false)
  // A licence unlocks a compliance class. No licence, no capability.
  unlocksClass    ComplianceClass

  @@index([sellerId])
}

// ─────────────────────────── CATALOGUE ───────────────────────────

model Product {
  id              String          @id @default(uuid())
  sellerId        String
  seller          Seller          @relation(fields: [sellerId], references: [id])
  title           String
  slug            String          @unique
  complianceClass ComplianceClass
  listingState    ListingState    @default(DRAFT)
  mrpPaise        Int
  pricePaise      Int
  hsn             String?
  description     String?
  createdAt       DateTime        @default(now())

  batches   Batch[]
  orderItems OrderItem[]

  // A2: a product is only sellable through a batch with an APPROVED, batch-matched CoA.
  // There is no `forceSellable` column. Do not add one.
  @@index([sellerId, listingState])
  @@index([complianceClass])
}

model Batch {
  id         String   @id @default(uuid())
  productId  String
  product    Product  @relation(fields: [productId], references: [id])
  batchCode  String
  mfgDate    DateTime
  expiryDate DateTime
  quantity   Int

  labReport LabReport?

  @@unique([productId, batchCode])
  @@index([expiryDate])
}

model LabReport {
  id           String          @id @default(uuid())
  batchId      String          @unique
  batch        Batch           @relation(fields: [batchId], references: [id])
  // The CoA must be issued for THIS batch — the batch code on the report must match.
  batchCode    String
  labName      String
  nablNumber   String
  thcPercent   Decimal         @db.Decimal(5, 3)
  cbdPercent   Decimal         @db.Decimal(5, 3)
  objectKey    String // S3 key, object-locked bucket
  status       LabReportStatus @default(PENDING)
  verifiedById String? // AdminUser (ADMIN_COMPLIANCE) — a human, never a service account
  verifiedAt   DateTime?
  createdAt    DateTime        @default(now())

  // A2 constraints in migration 0001:
  //   CHECK (status <> 'APPROVED' OR verified_by_id IS NOT NULL)
  //   CHECK (status <> 'APPROVED' OR thc_percent <= 0.300)
  //   CHECK (batch_code = (SELECT batch_code FROM "Batch" WHERE id = batch_id))  -- via trigger
  @@index([status])
}

// ─────────────────────────── ORDERS & MONEY ───────────────────────────

model Order {
  id          String      @id @default(uuid())
  reference   String      @unique // VH2026071234
  userId      String
  user        User        @relation(fields: [userId], references: [id])
  status      OrderStatus @default(PLACED)
  // Server-computed. A client-supplied total is rejected at the API.
  subtotalPaise Int
  taxPaise      Int
  totalPaise    Int
  idempotencyKey String    @unique
  placedAt    DateTime    @default(now())

  items OrderItem[]

  @@index([userId, status])
}

model OrderItem {
  id             String  @id @default(uuid())
  orderId        String
  order          Order   @relation(fields: [orderId], references: [id])
  productId      String
  product        Product @relation(fields: [productId], references: [id])
  batchId        String // FEFO-allocated. Recall and expiry act on the batch.
  quantity       Int
  unitPricePaise Int
  // For MED_CANNABIS lines, the prescription that authorised the sale.
  prescriptionId String?

  @@index([orderId])
}

model Wallet {
  id           String @id @default(uuid())
  userId       String @unique
  user         User   @relation(fields: [userId], references: [id])
  balancePaise Int    @default(0)

  entries WalletEntry[]
}

// Append-only ledger. REVOKE UPDATE, DELETE — see migration 0001.
model WalletEntry {
  id            String   @id @default(uuid())
  walletId      String
  wallet        Wallet   @relation(fields: [walletId], references: [id])
  deltaPaise    Int
  balanceAfter  Int
  reason        String
  reference     String?
  // A6: any adjustment (not an order payment) needs two humans.
  makerId       String?
  checkerId     String?
  at            DateTime @default(now())

  @@index([walletId, at])
}

model CommissionSchedule {
  id              String          @id @default(uuid())
  complianceClass ComplianceClass
  ratePpm         Int // parts per million; 110_000 = 11%
  noticeSentAt    DateTime
  effectiveFrom   DateTime
  createdById     String

  // A5: CHECK (effective_from >= notice_sent_at + interval '30 days')
  @@index([complianceClass, effectiveFrom])
}

model Settlement {
  id           String           @id @default(uuid())
  sellerId     String
  seller       Seller           @relation(fields: [sellerId], references: [id])
  periodStart  DateTime
  periodEnd    DateTime
  grossPaise   Int
  deductionsPaise Int
  netPaise     Int
  status       SettlementStatus @default(DRAFT)
  // A6: maker ≠ checker, both human, enforced by CHECK constraint.
  makerId      String
  checkerId    String?
  postedAt     DateTime? // once posted, immutable. Corrections are new adjustment rows.

  @@index([sellerId, status])
}

// ─────────────────────────── HEALTH DATA (A4) ───────────────────────────

model Prescription {
  id           String             @id @default(uuid())
  userId       String
  user         User               @relation(fields: [userId], references: [id])
  doctorName   String
  councilReg   String
  issuedAt     DateTime
  validTill    DateTime
  refills      Int                @default(0)
  refillsUsed  Int                @default(0)
  status       PrescriptionStatus @default(PENDING)
  // Encrypted at rest with a separate KMS CMK. Access only via 5-min signed URL.
  objectKey    String
  // A pharmacist signs. The model extracts; it never approves.
  verifiedById String?
  verifiedAt   DateTime?
  createdAt    DateTime           @default(now())

  @@index([userId, status])
}

// A4: every read of health data writes here, with a reason, before the object is served.
// The buyer is notified. REVOKE UPDATE, DELETE.
model SensitiveAccessLog {
  id             String   @id @default(uuid())
  actorId        String
  actorRoles     String[]
  subjectUserId  String
  entityType     String // Prescription | MedicalNote | ConsultationNote
  entityId       String
  reasonCode     String // PRESCRIPTION_VERIFICATION | ADVERSE_EVENT_TRIAGE | REGULATORY_REQUEST | DISPUTE_EVIDENCE
  reasonText     String
  buyerNotifiedAt DateTime?
  at             DateTime @default(now())

  @@index([subjectUserId, at])
  @@index([actorId, at])
}

// ─────────────────────────── ADVERTISING (A1) ───────────────────────────

model AdCampaign {
  id              String          @id @default(uuid())
  sellerId        String
  seller          Seller          @relation(fields: [sellerId], references: [id])
  name            String
  // A1: there is deliberately NO `complianceClass = MED_CANNABIS` path.
  // The CHECK constraint in migration 0001 rejects it at the database.
  complianceClass ComplianceClass
  dailyBudgetPaise Int
  active          Boolean         @default(false)
  createdAt       DateTime        @default(now())

  @@index([sellerId, active])
}

// Logged when something tried to advertise an ineligible class.
// blocked = false is a SEV-1 incident: it should be impossible.
model AdClassViolation {
  id        String   @id @default(uuid())
  layer     String // API | INDEX | AUCTION
  productId String
  blocked   Boolean
  at        DateTime @default(now())
}

// ─────────────────────────── SAFETY & AUDIT (A3) ───────────────────────────

// REVOKE DELETE, UPDATE. Object-lock mirrored. Corrections are new rows.
model AuditLog {
  id            BigInt       @id @default(autoincrement())
  at            DateTime     @default(now())
  actorId       String
  actorRoles    String[]
  elevationId   String?
  impersonatedUserId String?
  actionCode    String
  entityType    String
  entityId      String
  before        Json?
  after         Json?
  reasonCode    String
  reasonText    String?
  makerId       String?
  checkerId     String?
  requestId     String
  ip            String?
  outcome       AuditOutcome // DENIED actions are logged too.

  @@index([entityType, entityId, at])
  @@index([actorId, at])
}

model AdverseEvent {
  id          String   @id @default(uuid())
  productId   String
  batchId     String?
  reportedBy  String
  narrative   String
  acknowledgedAt DateTime?
  at          DateTime @default(now())
  // A3: no delete, no update. A correction is a new row referencing this id.
  correctsId  String?
}

model Recall {
  id         String    @id @default(uuid())
  batchId    String
  reason     String
  quarantinedAt DateTime  @default(now())
  buyersAffected Int
  buyersNotified Int      @default(0)
  // Initiation and closure both require maker–checker.
  makerId    String
  checkerId  String?
  closedAt   DateTime?
}
